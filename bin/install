#!/usr/bin/env bash
set -euo pipefail

# Intercom installer
# 1. Installs dependencies
# 2. Registers intercom in global MCP config (tools everywhere)
# 3. Adds .mcp.json to a target project (channels for real-time delivery)

# --- Resolve repo root from this script's location ---

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SERVER_PATH="$REPO_ROOT/source/intercom.ts"

# Target project is the first argument, or current directory
TARGET_PROJECT="${1:-.}"
TARGET_PROJECT="$(cd "$TARGET_PROJECT" 2>/dev/null && pwd)" || {
  echo "Error: directory not found: $1"
  exit 1
}

# --- Check prerequisites ---

if ! command -v jq &>/dev/null; then
  echo "Error: jq is required but not installed."
  echo "  macOS:  brew install jq"
  echo "  Linux:  sudo apt install jq"
  exit 1
fi

if ! command -v bun &>/dev/null; then
  echo "Error: bun is required but not installed."
  echo "  Install: curl -fsSL https://bun.sh/install | bash"
  exit 1
fi

if [ ! -f "$SERVER_PATH" ]; then
  echo "Error: intercom server not found at $SERVER_PATH"
  echo "  Are you running this from the right repo?"
  exit 1
fi

# --- Install dependencies ---

echo "Installing dependencies..."
(cd "$REPO_ROOT/source" && bun install --silent)

# --- Build the intercom server entry ---

INTERCOM_ENTRY=$(jq -n \
  --arg server "$SERVER_PATH" \
  '{
    command: "bun",
    args: ["run", $server],
    type: "stdio"
  }')

# --- Configure global MCP server ---

MCP_GLOBAL="$HOME/.claude/.mcp.json"

if [ ! -f "$MCP_GLOBAL" ]; then
  mkdir -p "$(dirname "$MCP_GLOBAL")"
  echo '{"mcpServers":{}}' > "$MCP_GLOBAL"
fi

jq --argjson entry "$INTERCOM_ENTRY" \
  '.mcpServers.intercom = $entry' \
  "$MCP_GLOBAL" > "$MCP_GLOBAL.tmp" && mv "$MCP_GLOBAL.tmp" "$MCP_GLOBAL"

echo "  Global:  $MCP_GLOBAL (tools available in all sessions)"

# --- Configure project-level .mcp.json ---

MCP_PROJECT="$TARGET_PROJECT/.mcp.json"

if [ -f "$MCP_PROJECT" ]; then
  # Add or update intercom entry, preserve everything else
  jq --argjson entry "$INTERCOM_ENTRY" \
    '.mcpServers.intercom = $entry' \
    "$MCP_PROJECT" > "$MCP_PROJECT.tmp" && mv "$MCP_PROJECT.tmp" "$MCP_PROJECT"
else
  # Create new project config
  jq -n --argjson entry "$INTERCOM_ENTRY" \
    '{ mcpServers: { intercom: $entry } }' > "$MCP_PROJECT"
fi

echo "  Project: $MCP_PROJECT (channels for real-time delivery)"

# --- Summary ---

echo ""
echo "Done. Intercom is installed."
echo ""
echo "  Server: $SERVER_PATH"
echo ""
echo "Start a session:"
echo ""
echo "  cd $TARGET_PROJECT"
echo "  export INTERCOM_AGENT_ID=my-agent"
echo "  claude --dangerously-load-development-channels server:intercom"
echo ""
echo "Without INTERCOM_AGENT_ID, the agent defaults to \"unknown\" (fine for casual use)."
