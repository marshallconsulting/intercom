#!/usr/bin/env bash
set -euo pipefail

# Intercom installer
# Registers intercom as a global MCP server in ~/.claude/.mcp.json
# so every Claude Code session has messaging access without per-repo setup.

# --- Resolve repo root from this script's location ---

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SERVER_PATH="$REPO_ROOT/source/intercom.ts"

# --- Check prerequisites ---

if ! command -v jq &>/dev/null; then
  echo "Error: jq is required but not installed."
  echo "  macOS:  brew install jq"
  echo "  Linux:  sudo apt install jq"
  exit 1
fi

if ! command -v bun &>/dev/null; then
  echo "Error: bun is required but not installed."
  echo "  Install: curl -fsSL https://bun.sh/install | bash"
  exit 1
fi

if [ ! -f "$SERVER_PATH" ]; then
  echo "Error: intercom server not found at $SERVER_PATH"
  echo "  Are you running this from the right repo?"
  exit 1
fi

# --- Install dependencies ---

echo "Installing dependencies..."
(cd "$REPO_ROOT/source" && bun install --silent)

# --- Configure global MCP server ---

MCP_CONFIG="$HOME/.claude/.mcp.json"

# Create the config file if it doesn't exist
if [ ! -f "$MCP_CONFIG" ]; then
  mkdir -p "$(dirname "$MCP_CONFIG")"
  echo '{"mcpServers":{}}' > "$MCP_CONFIG"
  echo "Created $MCP_CONFIG"
fi

# Build the intercom server entry
INTERCOM_ENTRY=$(jq -n \
  --arg server "$SERVER_PATH" \
  '{
    command: "bun",
    args: ["run", $server],
    type: "stdio"
  }')

# Add or update the intercom entry, preserving all other servers
jq --argjson entry "$INTERCOM_ENTRY" \
  '.mcpServers.intercom = $entry' \
  "$MCP_CONFIG" > "$MCP_CONFIG.tmp" && mv "$MCP_CONFIG.tmp" "$MCP_CONFIG"

echo ""
echo "Done. Intercom is configured as a global MCP server."
echo ""
echo "  Config:  $MCP_CONFIG"
echo "  Server:  $SERVER_PATH"
echo ""
echo "Every new Claude Code session now has access to intercom tools"
echo "(send, broadcast, list_agents)."
echo ""
echo "To set your agent ID, export CLAUDE_AGENT_ID before launching Claude Code:"
echo ""
echo "  export CLAUDE_AGENT_ID=my-agent"
echo "  claude"
echo ""
echo "Without it, the agent defaults to \"unknown\" (fine for casual use)."
echo ""
echo "If you have per-repo .mcp.json entries for intercom in other projects,"
echo "you can remove them. The global config handles it now."
