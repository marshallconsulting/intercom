#!/usr/bin/env bash
set -euo pipefail

# Resolve repo root from this script's location
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SERVER_PATH="$REPO_ROOT/source/intercom.ts"
MCP_CONFIG="$HOME/.claude/.mcp.json"

# Check dependencies
missing=()
command -v jq >/dev/null 2>&1 || missing+=("jq")
command -v bun >/dev/null 2>&1 || missing+=("bun")

if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Missing required tools: ${missing[*]}"
    echo ""
    for tool in "${missing[@]}"; do
        case "$tool" in
            jq)  echo "  Install jq:  https://jqlang.github.io/jq/download/" ;;
            bun) echo "  Install bun: https://bun.sh/" ;;
        esac
    done
    exit 1
fi

# Verify the server file exists
if [[ ! -f "$SERVER_PATH" ]]; then
    echo "Error: Server not found at $SERVER_PATH"
    echo "Make sure you're running this from the intercom repo."
    exit 1
fi

# Install dependencies
echo "Installing dependencies..."
(cd "$REPO_ROOT/source" && bun install --silent)

# Ensure ~/.claude/ directory exists
mkdir -p "$(dirname "$MCP_CONFIG")"

# Create config file if it doesn't exist
if [[ ! -f "$MCP_CONFIG" ]]; then
    echo '{"mcpServers":{}}' > "$MCP_CONFIG"
    echo "Created $MCP_CONFIG"
fi

# Add or update the intercom entry
UPDATED=$(jq --arg path "$SERVER_PATH" \
    '.mcpServers.intercom = {
        "command": "bun",
        "args": ["run", $path],
        "type": "stdio"
    }' "$MCP_CONFIG")

echo "$UPDATED" > "$MCP_CONFIG"

echo ""
echo "Intercom installed."
echo ""
echo "  Config:  $MCP_CONFIG"
echo "  Server:  $SERVER_PATH"
echo ""
echo "Every new Claude Code session now has intercom available."
echo ""
echo "Agent ID defaults to \"unknown\". To set a specific identity,"
echo "export CLAUDE_AGENT_ID before starting Claude Code:"
echo ""
echo "  export CLAUDE_AGENT_ID=my-agent"
echo ""
echo "If you have per-repo .mcp.json entries for intercom in other"
echo "projects, you can remove them. The global config handles it now."
